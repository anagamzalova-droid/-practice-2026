extern "C" {
    __declspec(dllexport) double FastDotProduct(double* a, double* b, int size) {
        double sum = 0.0;
        for (int i = 0; i < size; i++) {
            sum += a[i] * b[i];
        }
        return sum;
    }
    
    __declspec(dllexport) void VectorAdd(double* a, double* b, double* result, int size) {
        for (int i = 0; i < size; i++) {
            result[i] = a[i] + b[i];
        }
    }
