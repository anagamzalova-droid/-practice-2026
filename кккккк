public static class StatisticsHelper
{
    private const int DEFAULT_PRECISION = 2;
    
    public static double CalculateAverage(IEnumerable<double> values)
    {
        if (values == null || !values.Any())
            throw new ArgumentException("Коллекция не должна быть пустой");
            
        return values.Average();
    }
    
    public static string FormatWithPrecision(double value, int precision = DEFAULT_PRECISION)
    {
        return value.ToString($"F{precision}");
    }
}

// Использование:
var scores = listBoxScores.Items.Cast<double>();
double avg = StatisticsHelper.CalculateAverage(scores);
textBoxAverage.Text = StatisticsHelper.FormatWithPrecision(avg);
