public partial class MainPage : ContentPage
{
    private readonly DatabaseService _dbService;
    public MainPage()
    {
        InitializeComponent();
        _dbService = new DatabaseService();
    }
    private async void OnCalculateClicked(object sender, EventArgs e)
    {
        if (!double.TryParse(txtInput.Text, out double input))
        {
            await DisplayAlert("Ошибка", "Введите корректное число", "OK");
            return;
        }
        double result = 0;
        string operation = pickerOperation.SelectedItem?.ToString() ?? "Квадрат";
        switch (operation)
        {
            case "Квадрат":
                result = input * input;
                break;
            case "Корень":
                result = Math.Sqrt(input);
                break;
            case "Синус":
                result = Math.Sin(input * Math.PI / 180);
                break;
        }
        lblResult.Text = $"Результат: {result:F4}";
        // Сохранение в БД
        var calcResult = new CalculationResult
        {
            InputValue = input,
            ResultValue = result,
            OperationType = operation
        };
        await _dbService.SaveResultAsync(calcResult);
    }
    
    private async void OnHistoryClicked(object sender, EventArgs e)
    {
        await Navigation.PushAsync(new ResultsPage(_dbService));
    }
}
