<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobilePractice.MainPage">
    <VerticalStackLayout Spacing="15" Padding="20">
        <Entry x:Name="txtInput" 
               Placeholder="Введите число"
               Keyboard="Numeric"
               FontSize="20"/>
        <Picker x:Name="pickerOperation" Title="Выберите операцию">
            <Picker.Items>
                <x:String>Квадрат</x:String>
                <x:String>Корень</x:String>
                <x:String>Синус</x:String>
            </Picker.Items>
        </Picker>
        <Button x:Name="btnCalculate" 
                Text="Вычислить" 
                Clicked="OnCalculateClicked"
                BackgroundColor="#007AFF"
                TextColor="White"/>
        <Label x:Name="lblResult" 
               FontSize="18"
               HorizontalOptions="Center"/>
        <Button Text="История" 
                Clicked="OnHistoryClicked"
                BackgroundColor="#34C759"
                TextColor="White"/>
    </VerticalStackLayout>
</ContentPage>
