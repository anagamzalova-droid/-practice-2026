using SQLite;
namespace MobilePractice.Models;
[Table("calculations")]
public class CalculationResult
{
    [PrimaryKey, AutoIncrement]
    public int Id { get; set; }
        [Column("input_value")]
    public double InputValue { get; set; }
    [Column("result_value")]
    public double ResultValue { get; set; }
    [Column("operation_type")]
    public string OperationType { get; set; }
    [Column("created_at")]
    public DateTime CreatedAt { get; set; } = DateTime.Now;
}
Сервис базы данных:
csharp
using SQLite;
namespace MobilePractice.Services;
public class DatabaseService
{
    private SQLiteAsyncConnection _database;
    public DatabaseService()
    {
        InitializeAsync();
    }
    private async Task InitializeAsync()
    {
        var dbPath = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), "practice_mobile.db3");
        _database = new SQLiteAsyncConnection(dbPath);
        await _database.CreateTableAsync<CalculationResult>();
    }
        public async Task<List<CalculationResult>> GetAllResultsAsync()
    {
        return await _database.Table<CalculationResult>().ToListAsync();
    }
    public async Task<int> SaveResultAsync(CalculationResult result)
    {
        return await _database.InsertAsync(result);
    }
    public async Task<int> DeleteResultAsync(int id)
    {
        return await _database.DeleteAsync<CalculationResult>(id);
    }
}
